# =============================================================================
# IASA — Intelligent API Security Assessment
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=iasa
POSTGRES_PASSWORD=iasa_dev_password
POSTGRES_DB=iasa
POSTGRES_PORT=5432
DATABASE_URL=postgresql://iasa:iasa_dev_password@localhost:5432/iasa

# =============================================================================
# Cache & Queues (Redis)
# =============================================================================
REDIS_PASSWORD=iasa_redis_dev
REDIS_PORT=6379
REDIS_URL=redis://:iasa_redis_dev@localhost:6379

# =============================================================================
# Authentication (JWT)
# =============================================================================
# IMPORTANT: Change these in production! Use a strong random secret (32+ chars)
JWT_SECRET=change-this-in-production-minimum-32-chars-xxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change-refresh-secret-in-production-xxxxxxxxxxxxxxxx
REFRESH_TOKEN_EXPIRES_IN=30d

# =============================================================================
# Security
# =============================================================================
# 32-byte hex key for encrypting secrets stored in database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-encryption-key-32-chars-min-xxxxxxxxxxxxxxxx

# =============================================================================
# AI Analysis (Optional but recommended)
# =============================================================================
# OpenAI API key for AI-powered vulnerability analysis
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000

# Amazon Bedrock (Alternative to OpenAI)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# Scanner Configuration
# =============================================================================
MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT_MS=300000
MAX_REQUESTS_PER_ENDPOINT=50
RATE_LIMIT_TEST_REQUESTS=25
REQUEST_DELAY_MS=100

# =============================================================================
# Reports
# =============================================================================
REPORTS_DIR=./reports

# =============================================================================
# Frontend (Next.js)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=IASA
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_ENABLE_AI=true

# =============================================================================
# Observability (Optional)
# =============================================================================
GRAFANA_PASSWORD=admin
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
