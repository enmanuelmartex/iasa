// =============================================================================
// IASA — Prisma Schema
// Intelligent API Security Assessment
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum SpecSource {
  URL
  UPLOAD
  MANUAL
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  HEAD
  OPTIONS
  TRACE
}

enum AuthType {
  NONE
  BEARER
  BASIC
  API_KEY
  OAUTH2
  CUSTOM
}

enum ProjectStatus {
  DRAFT
  READY
}

enum AssessmentStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

/// Triage state of a persistent SecurityIssue.
///
/// The state belongs to the issue, not to any single detection: it survives
/// rescans and the deletion of the scan that first produced it.
enum IssueStatus {
  /// Detected and not yet triaged.
  OPEN
  /// A human has reviewed it and accepts it is real; remediation is pending.
  ACKNOWLEDGED
  /// Believed fixed. A later detection reopens it (see reopenCount).
  RESOLVED
  /// Real, but accepted as a business decision. Still counts as technical risk.
  ACCEPTED_RISK
  /// Judged not a real vulnerability. Never auto-reopened.
  FALSE_POSITIVE
}

/// Whether a single detection has been manually verified.
///
/// Distinct from IssueStatus: this records confidence in one observation,
/// not the triage decision for the underlying vulnerability.
enum OccurrenceValidation {
  UNVERIFIED
  VERIFIED
  REFUTED
}

/// Trustworthiness of a computed assessment score.
///
/// Prevents an incomplete run from being presented as a real result — the
/// defect where a failed scan displayed a perfect 100.
enum ScoreStatus {
  /// No score can be computed: queued, running, failed, cancelled, or no check
  /// completed successfully. `securityScore` MUST be null.
  UNAVAILABLE
  /// Computed, but some planned checks failed or were skipped, so the score
  /// reflects partial coverage. Must be labelled as provisional in the UI.
  PROVISIONAL
  /// Every planned check executed successfully. Only a FINAL score with zero
  /// findings may legitimately show 100.
  FINAL
}

/// Business importance of the API a project represents.
///
/// Deliberately separate from Environment: a staging system can be critical,
/// and a production system can be low-value.
enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportType {
  EXECUTIVE
  TECHNICAL
  COMPLIANCE
  DEVELOPER
}

enum ReportFormat {
  PDF
  HTML
  MARKDOWN
  JSON
  SARIF
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  SCAN_START
  SCAN_STOP
  ROLE_CHANGE
  PASSWORD_RESET
}

enum PluginCategory {
  AUTHENTICATION
  AUTHORIZATION
  HEADERS
  INJECTION
  API_DESIGN
  PERFORMANCE
  INFRASTRUCTURE
  COMPLIANCE
  AI
  CLOUD
  GRAPHQL
  GRPC
  SOAP
}

enum PluginExecutionStatus {
  SUCCESS
  FAILED
  TIMEOUT
  SKIPPED
}

// =============================================================================
// USER & ORGANIZATION
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String?
  role          Role      @default(ADMIN)
  avatar        String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  emailVerified Boolean   @default(false)
  ownerId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner              User?               @relation("OwnerMembers", fields: [ownerId], references: [id])
  members            User[]              @relation("OwnerMembers")
  sessions           Session[]
  accounts           Account[]
  sentInvitations    Invitation[]        @relation("InvitedByAdmin")
  projects           Project[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  pluginUserConfigs  PluginUserConfig[]
  scanProfiles       ScanProfile[]
  assignedIssues     SecurityIssue[]     @relation("IssueAssignee")
  issueStatusChanges IssueStatusChange[] @relation("IssueStatusActor")

  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPreview String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  scopes     String[]  @default(["read", "write"])

  createdAt DateTime @default(now())

  @@map("api_keys")
}

// =============================================================================
// BETTER AUTH — Sessions, Accounts, Verifications
// =============================================================================

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Better Auth resolves and revokes a user's sessions by userId.
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  /// Better Auth looks up linked accounts by userId on every sign-in.
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// =============================================================================
// INVITATIONS — Custom workspace invitation system
// =============================================================================

model Invitation {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(ANALYST)
  token       String    @unique
  invitedById String
  invitedBy   User      @relation("InvitedByAdmin", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  accepted    Boolean   @default(false)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("invitations")
}

// =============================================================================
// PROJECT
// =============================================================================

model Project {
  id               String           @id @default(cuid())
  name             String
  description      String?
  baseUrl          String
  environment      Environment      @default(DEVELOPMENT)
  /// Business importance of this API. Feeds security posture weighting.
  /// Separate from `environment`, which describes where it runs, not what it is worth.
  assetCriticality AssetCriticality @default(MEDIUM)
  tags             String[]         @default([])
  isActive         Boolean          @default(true)
  status           ProjectStatus    @default(READY)
  setupStep        Int              @default(3)
  completedAt      DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  apiSpec        ApiSpec?
  assessments    Assessment[]
  /// Persistent vulnerabilities. Owned by the project so scan deletion cannot
  /// remove them.
  securityIssues SecurityIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Every project listing is scoped to the owner and to active projects.
  @@index([userId, isActive])
  /// Dashboard splits projects by setup state (drafts vs ready-to-scan).
  @@index([userId, status])
  @@map("projects")
}

// `ProjectSecret` was removed in Phase 1B. It was declared with an
// "AES-256 encrypted" comment but had zero code references anywhere in the
// repository — nothing ever read or wrote it. Project credentials live in
// `AuthConfig`, which Phase 0 made genuinely encrypted.

// =============================================================================
// API SPECIFICATION
// =============================================================================

model ApiSpec {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  source  SpecSource
  url     String?
  rawSpec Json
  parsed  Json
  version String?
  title   String?
  format  String?    @default("openapi")

  authConfig AuthConfig?
  endpoints  Endpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_specs")
}

model AuthConfig {
  id        String  @id @default(cuid())
  apiSpecId String  @unique
  apiSpec   ApiSpec @relation(fields: [apiSpecId], references: [id], onDelete: Cascade)

  type AuthType @default(NONE)

  // Bearer token
  token String? // encrypted

  // Basic auth
  username String?
  password String? // encrypted

  // API Key
  apiKey         String? // encrypted
  apiKeyHeader   String? @default("X-API-Key")
  apiKeyLocation String? @default("header") // header | query

  // OAuth2
  clientId     String? // encrypted
  clientSecret String? // encrypted
  tokenUrl     String?
  scopes       String[]

  // Custom headers
  customHeaders Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("auth_configs")
}

model Endpoint {
  id        String  @id @default(cuid())
  apiSpecId String
  apiSpec   ApiSpec @relation(fields: [apiSpecId], references: [id], onDelete: Cascade)

  path        String
  method      HttpMethod
  summary     String?
  description String?
  operationId String?
  tags        String[]
  parameters  Json?
  requestBody Json?
  responses   Json?
  security    Json?
  deprecated  Boolean    @default(false)

  createdAt          DateTime            @default(now())
  findingOccurrences FindingOccurrence[]

  @@unique([apiSpecId, path, method])
  @@map("endpoints")
}

// =============================================================================
// ASSESSMENT
// =============================================================================

model Assessment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status      AssessmentStatus @default(PENDING)
  progress    Int              @default(0) // 0-100
  currentStep String?
  jobId       String? // BullMQ job ID

  config  AssessmentConfig?
  summary AssessmentSummary?

  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // seconds

  occurrences        FindingOccurrence[]
  /// Triage transitions this scan caused. SetNull on the far side, so deleting
  /// the scan detaches the history rather than deleting it.
  issueStatusChanges IssueStatusChange[]
  reports            Report[]
  logs               AssessmentLog[]
  pluginExecutions   PluginExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Scan history for one project, newest first (project detail → Scans tab).
  @@index([projectId, createdAt])
  /// "Running / failed scans needing attention" on the dashboard.
  @@index([projectId, status])
  /// Global scans list filtered by status across all projects.
  @@index([status, createdAt])
  @@map("assessments")
}

model AssessmentConfig {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // Execution mode controls which plugins run
  executionMode   String       @default("all") // "all" | "profile" | "manual"
  scanProfileId   String?
  scanProfile     ScanProfile? @relation(fields: [scanProfileId], references: [id], onDelete: SetNull)
  manualPlugins   String[]     @default([]) // plugin IDs for mode="manual"
  resolvedPlugins String[]     @default([]) // immutable effective plugin selection for this run

  // These settings always apply regardless of mode
  enableAiAnalysis       Boolean @default(true)
  maxRequestsPerEndpoint Int     @default(10)
  requestDelayMs         Int     @default(200)
  timeoutMs              Int     @default(10000)

  createdAt DateTime @default(now())

  @@map("assessment_configs")
}

model AssessmentSummary {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  totalEndpoints  Int @default(0)
  testedEndpoints Int @default(0)
  totalFindings   Int @default(0)
  criticalCount   Int @default(0)
  highCount       Int @default(0)
  mediumCount     Int @default(0)
  lowCount        Int @default(0)
  infoCount       Int @default(0)

  /// Immutable snapshot of the score at scan time, 0-100.
  ///
  /// NULLABLE AND WITHOUT A DEFAULT, deliberately. The previous `@default(100)`
  /// was the root cause of failed scans reporting a perfect score: the summary
  /// row was created before plugins ran, and the failure path never updated it,
  /// leaving a persisted 100. `null` now means "no score", and a real 0 stays 0.
  ///
  /// A score is only meaningful together with `scoreStatus`.
  securityScore    Float?
  /// UNAVAILABLE ⇒ securityScore MUST be null. Only FINAL may show 100.
  scoreStatus      ScoreStatus @default(UNAVAILABLE)
  /// Formula version that produced the score, e.g. "score-v1". Lets a future
  /// formula coexist without silently reinterpreting historical numbers.
  scoreVersion     String?
  scoreComputedAt  DateTime?
  /// Human-readable breakdown of what drove the score (severity contributions,
  /// exposure multipliers, coverage), so the number is explainable in the UI.
  scoreExplanation Json?

  riskLevel String @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL

  // ── Execution scope ────────────────────────────────────────────────────────
  // Kept separate from the score: coverage answers "how much did we look at?",
  // the score answers "how bad is what we found?". Conflating them is what made
  // the old OWASP "coverage" chart meaningless (it counted findings).
  //
  // In score-v1 these are counted in PLUGIN executions, the most granular unit
  // the scanner records today. Per-endpoint and per-rule execution tracking does
  // not exist yet, so coveragePercent must not be presented as endpoint or rule
  // coverage.
  plannedChecks    Int    @default(0)
  successfulChecks Int    @default(0)
  failedChecks     Int    @default(0)
  skippedChecks    Int    @default(0)
  executionErrors  Int    @default(0)
  /// successfulChecks / plannedChecks × 100. Null when nothing was planned.
  coveragePercent  Float?

  owaspCoverage Json? // OWASP categories covered
  pluginResults Json? // PluginExecutionPlan — available / executed / skipped / versions / durationMs / findingCounts
  aiStatus      Json? // AiAnalysisMeta — provider / model / available / analyzed / skipped / durationMs / tokensUsed / reason

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("assessment_summaries")
}

model AssessmentLog {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  level     String // info | warn | error
  plugin    String?
  message   String
  metadata  Json?
  timestamp DateTime @default(now())

  /// Scan detail loads this scan's logs in timestamp order.
  @@index([assessmentId, timestamp])
  @@map("assessment_logs")
}

// Finding and FindingStatus were removed in Phase 1C.6, after every consumer
// was migrated to SecurityIssue + FindingOccurrence. The model conflated a
// per-scan detection with cross-scan triage state, so the same vulnerability
// was re-inserted as a fresh OPEN row on every scan and deleting a scan
// cascaded away the triage attached to it.

// =============================================================================
// PERSISTENT VULNERABILITY DOMAIN
//
// Replaces the single `Finding` model, which conflated two different lifetimes
// in one row: per-scan detection data (evidence, request/response, assessmentId)
// and cross-scan triage state (status, notes). That conflation meant the same
// vulnerability was re-inserted on every scan as a fresh OPEN row, and deleting
// a scan cascaded away the triage work attached to it.
//
//   SecurityIssue     — the vulnerability. Persistent, owned by the PROJECT.
//   FindingOccurrence — one detection of it by one scan. Immutable.
//   IssueStatusChange — auditable history of triage decisions.
//
// `Finding` still exists during Phase 1A so this change is purely additive.
// Phase 1B removes it.
// =============================================================================

/// A vulnerability that persists across scans, identified by a fingerprint.
///
/// Hangs off Project, never off Assessment: deleting a scan must not be able to
/// erase a vulnerability or the triage decisions made about it.
model SecurityIssue {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ── Identity ───────────────────────────────────────────────────────────────
  //
  // fingerprint = SHA-256 of the canonical string
  //   v1|projectId|pluginId|ruleId|METHOD|normalizedRoute|component
  //
  // The inputs are stored alongside the hash so identity stays explainable and
  // recomputable, and so a future v2 formula can be backfilled by comparison.
  // Deliberately excluded from the hash: title, description, severity, evidence,
  // AI output, timestamps, occurrence ids — anything that may change wording or
  // scoring without changing which vulnerability is being described.
  fingerprint        String
  fingerprintVersion String @default("v1")

  pluginId        String
  ruleId          String
  /// Uppercase HTTP method, or "GLOBAL" for project-wide issues.
  method          String
  /// Template path (`/users/{id}`), never a concrete path. "/" when GLOBAL.
  normalizedRoute String
  /// Stable identifier of the affected area: "endpoint", "header:authorization",
  /// "query:user_id", "path:param", "body:password", "response:content-type",
  /// or "project" for project-wide issues.
  component       String

  // ── Current presentation ───────────────────────────────────────────────────
  // Mutable: refreshed from the newest occurrence. Rewording a check's message
  // must never change issue identity, so none of this feeds the fingerprint.
  title         String
  description   String
  severity      Severity
  owaspCategory String
  cweId         String?
  cvssScore     Float?
  cvssVector    String?

  // ── Triage ─────────────────────────────────────────────────────────────────
  status IssueStatus @default(OPEN)
  notes  String?

  assigneeId String?
  assignee   User?   @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  /// When an ACCEPTED_RISK acceptance lapses. On expiry the issue returns to OPEN.
  acceptedRiskUntil DateTime?

  // ── Lifecycle ──────────────────────────────────────────────────────────────
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  resolvedAt      DateTime?
  reopenedAt      DateTime?
  reopenCount     Int       @default(0)
  occurrenceCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  occurrences   FindingOccurrence[]
  statusChanges IssueStatusChange[]

  /// The core deduplication guarantee: one logical vulnerability per project per
  /// fingerprint formula. A rescan finds this row instead of inserting a duplicate.
  /// Versioned so introducing a v2 formula cannot silently collide with v1 rows.
  @@unique([projectId, fingerprintVersion, fingerprint])
  /// Issues list filtered by status; project posture counts open/confirmed issues.
  @@index([projectId, status])
  /// Issues list filtered/sorted by severity; posture weights issues by severity.
  @@index([projectId, severity])
  /// "Recently seen" ordering on the project Issues tab and staleness checks.
  @@index([projectId, lastSeenAt])
  /// "Issues assigned to me".
  @@index([assigneeId])
  /// Detection-coverage and per-check reporting within a project.
  @@index([projectId, pluginId])
  /// Sweep for lapsed risk acceptances that must return to OPEN.
  @@index([status, acceptedRiskUntil])
  @@map("security_issues")
}

/// One immutable detection of a SecurityIssue by one assessment.
///
/// Carries `*Snapshot` copies of everything a report needs, so historical
/// reports stay accurate even after the spec is re-imported (which deletes and
/// recreates every Endpoint row), a check is reworded, or a severity is retuned.
model FindingOccurrence {
  id           String        @id @default(cuid())
  issueId      String
  issue        SecurityIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment   Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  /// Best-effort link to the endpoint. SetNull because re-importing a spec
  /// recreates endpoints with new ids; the snapshots below are the durable record.
  endpointId String?
  endpoint   Endpoint? @relation(fields: [endpointId], references: [id], onDelete: SetNull)

  /// Deterministic idempotency token: SHA-256 of `fingerprintVersion|fingerprint`.
  ///
  /// Derived purely from issue identity, so the worker can compute it before any
  /// row exists and persist with skipDuplicates. Combined with the unique
  /// constraint below, a BullMQ retry of a partially-completed job re-inserts
  /// nothing instead of duplicating detections. Never derived from time,
  /// randomness or row ids.
  occurrenceKey String

  // ── Immutable snapshots ────────────────────────────────────────────────────
  methodSnapshot        String
  pathSnapshot          String
  operationIdSnapshot   String?
  pluginIdSnapshot      String
  pluginVersionSnapshot String
  ruleIdSnapshot        String
  severitySnapshot      Severity
  cvssSnapshot          Float?
  owaspSnapshot         String
  cweSnapshot           String?
  titleSnapshot         String
  descriptionSnapshot   String
  impactSnapshot        String?
  remediationSnapshot   String?

  // ── Evidence (redacted before persistence — see common/utils/redact.util) ──
  evidence     Json?
  httpRequest  String?
  httpResponse String?
  affectedUrl  String?
  /// The affected component for this detection; mirrors SecurityIssue.component.
  location     String

  validation OccurrenceValidation @default(UNVERIFIED)

  // ── Provenance ─────────────────────────────────────────────────────────────
  /// Hash of the effective scan configuration, so a result can be tied to the
  /// exact settings that produced it.
  assessmentConfigHash String?
  specVersionSnapshot  String?

  detectedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  /// Idempotency guarantee. Because occurrenceKey is a pure function of issue
  /// identity, this enforces "at most one detection of a given vulnerability per
  /// scan" and makes worker retries safe at the database level rather than
  /// relying on in-memory bookkeeping.
  @@unique([assessmentId, occurrenceKey])
  /// Occurrence history on the issue detail page, newest first.
  @@index([issueId, detectedAt])
  /// "Findings from this scan" on the scan detail page.
  @@index([assessmentId])
  /// "Issues affecting this endpoint" on the project Endpoints tab.
  @@index([endpointId])
  @@map("finding_occurrences")
}

/// Auditable history of every triage transition on an issue.
///
/// Written on every status change, including automatic ones (reopen on
/// recurrence, expiry of an accepted risk). `SecurityIssue.status` is the
/// current value; this table is why it holds that value.
model IssueStatusChange {
  id      String        @id @default(cuid())
  issueId String
  issue   SecurityIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  /// Null on the initial transition into OPEN when the issue is created.
  fromStatus IssueStatus?
  toStatus   IssueStatus

  /// Null when the change was made by the system rather than a person.
  actorId String?
  actor   User?   @relation("IssueStatusActor", fields: [actorId], references: [id], onDelete: SetNull)

  /// The scan that triggered an automatic change, when applicable.
  ///
  /// SetNull — deleting a scan must never destroy triage history. This is the
  /// specific cascade that made the old model lose triage work.
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  /// Required by the UI for FALSE_POSITIVE, ACCEPTED_RISK and RESOLVED.
  reason String?

  /// True when the system made the change (recurrence reopen, acceptance expiry).
  automatic Boolean @default(false)

  /// Expiry recorded at the moment risk was accepted.
  acceptedRiskUntil DateTime?

  createdAt DateTime @default(now())

  /// Activity timeline for one issue, newest first.
  @@index([issueId, createdAt])
  /// "What did this user triage?" for audit review.
  @@index([actorId])
  @@map("issue_status_changes")
}

// =============================================================================
// REPORT
// =============================================================================

model Report {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  type     ReportType
  format   ReportFormat
  title    String
  filePath String?
  fileSize Int?
  content  String? // For text-based formats
  checksum String? // SHA256 of file

  generatedAt DateTime @default(now())

  /// Reports of one scan (reports list grouping, scan detail → Reports).
  @@index([assessmentId])
  @@map("reports")
}

// =============================================================================
// PLUGIN MANAGEMENT
// =============================================================================

model Plugin {
  id                 String         @id // stable slug: "bola", "jwt-analysis"
  name               String
  version            String         @default("1.0.0")
  description        String
  longDescription    String?
  author             String         @default("IASA Core Team")
  category           PluginCategory
  owaspMappings      String[]
  cweIds             String[]       @default([])
  tags               String[]       @default([])
  isBuiltin          Boolean        @default(true)
  isEnabled          Boolean        @default(true) // global default
  configSchema       Json? // JSON Schema for config UI
  defaultConfig      Json?
  permissions        String[]       @default([])
  documentationUrl   String?
  changelog          String?
  minimumCoreVersion String         @default("1.0.0")
  license            String         @default("MIT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userConfigs PluginUserConfig[]
  executions  PluginExecution[]

  @@map("plugins")
}

model PluginUserConfig {
  id        String  @id @default(cuid())
  pluginId  String
  userId    String
  isEnabled Boolean @default(true)
  config    Json? // user overrides for configSchema fields

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pluginId, userId])
  @@map("plugin_user_configs")
}

model PluginExecution {
  id            String                @id @default(cuid())
  pluginId      String
  assessmentId  String?
  userId        String
  status        PluginExecutionStatus
  startedAt     DateTime
  completedAt   DateTime?
  durationMs    Int?
  findingsCount Int                   @default(0)
  errorMessage  String?
  metadata      Json?

  createdAt DateTime @default(now())

  plugin     Plugin      @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  /// Execution history for one check (plugins/:id/executions), newest first.
  @@index([pluginId, startedAt])
  /// Which checks actually ran in a scan — the basis for scope-aware comparison.
  @@index([assessmentId])
  @@map("plugin_executions")
}

model ScanProfile {
  id             String   @id @default(cuid())
  name           String
  description    String?
  icon           String?
  userId         String? // null = system profile
  isSystem       Boolean  @default(false)
  enabledPlugins String[] // array of plugin IDs
  pluginConfigs  Json? // per-plugin config overrides

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentConfigs AssessmentConfig[]

  @@map("scan_profiles")
}

// =============================================================================
// AI CONFIGURATION
// =============================================================================

/// One row per AI provider. Only one row has isActive=true at a time.
/// API keys stored AES-256-CBC encrypted (iv_hex:ciphertext_hex).
model AiProviderConfig {
  id               String    @id @default(cuid())
  provider         String    @unique // openai | grok | claude | gemini | ollama
  model            String?
  apiKey           String? // encrypted
  baseUrl          String? // Ollama / custom
  isActive         Boolean   @default(false)
  profile          String    @default("balanced")
  analyzeCritical  Boolean   @default(true)
  analyzeHigh      Boolean   @default(true)
  analyzeMedium    Boolean   @default(false)
  analyzeLow       Boolean   @default(false)
  executiveSummary Boolean   @default(true)
  maxTokens        Int?
  temperature      Float?
  timeoutMs        Int?
  maxFindings      Int?
  retryAttempts    Int       @default(2)
  lastTestedAt     DateTime?
  lastTestSuccess  Boolean?
  lastTestMessage  String?
  configuredAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("ai_provider_configs")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  success    Boolean     @default(true)

  createdAt DateTime @default(now())

  /// Audit log default view: newest first, paginated.
  @@index([createdAt])
  /// Audit log filtered by user.
  @@index([userId, createdAt])
  @@map("audit_logs")
}
