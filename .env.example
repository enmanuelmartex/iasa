# =============================================================================
# IASA — Environment Configuration
#
# Copy to .env and fill in real values:
#     cp .env.example .env
#
# The API validates the security-critical variables at startup and REFUSES TO
# BOOT if any is missing, too short, or still a placeholder. There are no
# hardcoded fallbacks — a secret committed to a repository is a public secret.
#
# Generate every secret below with:
#     openssl rand -hex 32
# =============================================================================

# ── REQUIRED — application will not start without these ──────────────────────

# PostgreSQL connection string.
DATABASE_URL=postgresql://iasa:iasa_dev_password@localhost:5432/iasa

# Signs access tokens. Minimum 32 characters. NEVER reuse across environments.
JWT_SECRET=

# Signs refresh tokens. Minimum 32 characters. MUST differ from JWT_SECRET.
REFRESH_TOKEN_SECRET=

# Encrypts stored credentials (project auth configs, AI provider API keys)
# with AES-256-GCM.
#
# EXACT FORMAT — 64 hexadecimal characters (32 bytes), optional "hex:" prefix:
#     ENCRYPTION_KEY=<64 hex chars>
#     ENCRYPTION_KEY=hex:<64 hex chars>
#
# Generate with:
#     openssl rand -hex 32
#
# Anything else is rejected at startup. The key is never padded, truncated or
# re-encoded: a value that does not match this contract is an error, not
# something the application silently coerces into a key.
#
# WARNING: changing this makes every previously stored credential undecryptable.
# They must then be re-entered. Back it up alongside your database.
ENCRYPTION_KEY=

# ── Core services ────────────────────────────────────────────────────────────

REDIS_URL=redis://:iasa_dev_password@localhost:6379

API_PORT=4000
WEB_PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Docker Compose (used by docker-compose.yml) ──────────────────────────────

POSTGRES_USER=iasa
POSTGRES_PASSWORD=iasa_dev_password
POSTGRES_DB=iasa
POSTGRES_PORT=5432
REDIS_PASSWORD=iasa_dev_password
REDIS_PORT=6379

# ── Better Auth ──────────────────────────────────────────────────────────────

# Minimum 32 characters.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# Optional — Google OAuth sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Scanner ──────────────────────────────────────────────────────────────────

MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT_MS=300000
MAX_REQUESTS_PER_ENDPOINT=10
RATE_LIMIT_TEST_REQUESTS=25
REQUEST_DELAY_MS=100
REPORTS_DIR=./reports

# SSRF policy for scan targets and OpenAPI spec URLs.
#
# false (default): private, loopback, link-local and reserved ranges are
#   blocked. Correct for any hosted/shared deployment.
# true: allows scanning APIs on private networks. Only set this when running
#   IASA locally against your own infrastructure.
ALLOW_PRIVATE_TARGETS=false

# Set to true when the API runs inside Docker and must reach the host via
# host.docker.internal instead of localhost.
DOCKER_ENV=false

# ── AI enrichment (optional) ─────────────────────────────────────────────────
#
# AI is a post-processor: it enriches findings but never creates, re-scores or
# resolves them. A scan completes normally when AI is unavailable.
#
# Provider: openai | grok | claude | gemini | ollama | none
AI_PROVIDER=none

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=30000
OPENAI_MAX_FINDINGS=10
OPENAI_ANALYZE_CRITICAL=true
OPENAI_ANALYZE_HIGH=true
OPENAI_ANALYZE_MEDIUM=false
OPENAI_ANALYZE_LOW=false
OPENAI_EXECUTIVE_SUMMARY=true

# GROQ_API_KEY=
# CLAUDE_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ── Frontend (NEXT_PUBLIC_* is exposed to the browser — never put secrets here)

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=IASA
NEXT_PUBLIC_APP_VERSION=0.2.0
NEXT_PUBLIC_ENABLE_AI=true

# ── Optional integrations ────────────────────────────────────────────────────

# RESEND_API_KEY=
# RESEND_FROM=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# GRAFANA_PASSWORD=
